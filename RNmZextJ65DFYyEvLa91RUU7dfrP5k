		local mainCoin = visual:FindFirstChild("MainCoin")
		if not mainCoin or mainCoin.Transparency ~= 0 then return false end
		return true
	end

	local function getNearestCoin(hrp)
		local coinFolder = workspace:FindFirstChild("CoinContainer", true)
		if not coinFolder then return nil end

		local nearestCoin = nil
		local nearestDistance = math.huge

		for _, coinServer in coinFolder:GetChildren() do
			if isCoinValid(coinServer) then
				local distance = (coinServer.Position - hrp.Position).Magnitude
				if distance < nearestDistance then
					nearestCoin = coinServer
					nearestDistance = distance
				end
			end
		end

		return nearestCoin
	end

	local function updateCoinsPerHour()
		local now = os.clock()

		if lastCollectTime then
			local gap = now - lastCollectTime
			table.insert(collectionIntervals, gap)

			if #collectionIntervals > MAX_INTERVAL_SAMPLES then
				table.remove(collectionIntervals, 1)
			end
		end

		lastCollectTime = now

		if #collectionIntervals > 0 then
			local sum = 0
			for _, gap in collectionIntervals do
				sum += gap
			end
			local avgInterval = sum / #collectionIntervals

			if avgInterval > 0 then
				COINS_PER_HOUR = math.floor(3600 / avgInterval)
			end
		end
	end

	local function Collect(coin, hrp)
		local visual = coin:FindFirstChild("CoinVisual")
		if not visual then return end

		STATUS = "Collecting..."

		local startTime = os.clock()
		local TIMEOUT = 3

		while true do
			if not isCoinValid(coin) then return end
			if os.clock() - startTime > TIMEOUT then return end

			local dist = (coin.Position - hrp.Position).Magnitude
			if dist < 5 then
				-- TODO: replace with your real collection call, e.g.:
				-- coinCollectRemote:FireServer(coin)
				coin.CFrame = hrp.CFrame
				TOTAL_COLLECTED += 1
				updateCoinsPerHour()
				return
			end

			task.wait(0.1)
		end
	end

	local function getPathLength(startPos, targetPos)
		local testPath = PathfindingService:CreatePath({
			AgentRadius = 2,
			AgentHeight = 5,
			AgentCanJump = true,
			AgentCanClimb = true,
		})

		local ok = pcall(function()
			testPath:ComputeAsync(startPos, targetPos)
		end)

		if not ok or testPath.Status ~= Enum.PathStatus.Success then
			return math.huge
		end

		local waypoints = testPath:GetWaypoints()
		local length = 0
		for i = 2, #waypoints do
			length += (waypoints[i].Position - waypoints[i - 1].Position).Magnitude
		end

		return length
	end

	local function waitForWaypoint(humanoid, hrp, coin)
		local reached = false
		local rerouted = false
		local broken = false

		local conn
		conn = humanoid.MoveToFinished:Connect(function(didReach)
			reached = true
		end)

		local startTime = os.clock()
		local lastRerouteCheck = 0

		while not reached do
			if os.clock() - startTime > WAYPOINT_TIMEOUT then
				broken = true
				break
			end

			if not isCoinValid(coin) then
				broken = true
				break
			end

			local character = player.Character
			local currentHrp = character and character:FindFirstChild("HumanoidRootPart")
			if not currentHrp then
				broken = true
				break
			end

			if os.clock() - lastRerouteCheck >= REROUTE_CHECK_INTERVAL then
				lastRerouteCheck = os.clock()
				local closer = getNearestCoin(currentHrp)
				if closer and closer ~= coin then
					local closerPathLen = getPathLength(currentHrp.Position, closer.Position)
					local currentPathLen = getPathLength(currentHrp.Position, coin.Position)
					if closerPathLen < currentPathLen - REROUTE_MARGIN then
						rerouted = true
						break
					end
				end
			end

			task.wait(0)
		end

		conn:Disconnect()
		return reached, rerouted, broken
	end

	local function navigateToCoin(coin)
		local indicators = {}
		local handles = nil

		local success, err = pcall(function()
			local character = player.Character
			local hrp = character and character:FindFirstChild("HumanoidRootPart")
			local humanoid = character and character:FindFirstChild("Humanoid")
			if not hrp or not humanoid then return end

			STATUS = "Moving..."

			local newPath = PathfindingService:CreatePath({
				AgentRadius = 2,
				AgentHeight = 5,
				AgentCanJump = true,
				AgentCanClimb = true,
			})

			newPath:ComputeAsync(hrp.Position, coin.Position)
			if newPath.Status ~= Enum.PathStatus.Success then return end

			for i, waypoint in newPath:GetWaypoints() do
				local indicatorPart = Instance.new("Part")
				indicatorPart.Size = Vector3.new(0.5, 0.5, 0.5)
				indicatorPart.Anchored = true
				indicatorPart.CanCollide = false
				indicatorPart.Transparency = 0
				indicatorPart.Color = Color3.new(0.388235, 1, 0.321569)
				indicatorPart.Position = waypoint.Position
				indicatorPart.Material = Enum.Material.Neon
				indicatorPart.Shape = Enum.PartType.Ball
				indicatorPart.Parent = workspace
				indicators[i] = indicatorPart
			end

			handles = Instance.new("BoxHandleAdornment")
			handles.Parent = coin
			handles.Adornee = coin
			handles.AlwaysOnTop = true
			handles.Color3 = Color3.fromRGB(251, 255, 1)
			handles.ZIndex = 10

			local finishedWaypoints = 0
			local wasRerouted = false

			for i, waypoint in newPath:GetWaypoints() do
				local currentCharacter = player.Character
				local currentHrp = currentCharacter and currentCharacter:FindFirstChild("HumanoidRootPart")
				local currentHumanoid = currentCharacter and currentCharacter:FindFirstChild("Humanoid")

				if not currentHrp or not currentHumanoid or not isCoinValid(coin) then break end

				if waypoint.Action == Enum.PathWaypointAction.Jump then
					currentHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				end

				currentHumanoid:MoveTo(waypoint.Position)
				local reached, rerouted, broken = waitForWaypoint(currentHumanoid, currentHrp, coin)

				if indicators[i] then
					indicators[i]:Destroy()
					indicators[i] = nil
				end

				if rerouted or broken then
					wasRerouted = rerouted
					break
				end

				finishedWaypoints += 1
			end

			if not wasRerouted and finishedWaypoints == #newPath:GetWaypoints() then
				local finalCharacter = player.Character
				local finalHrp = finalCharacter and finalCharacter:FindFirstChild("HumanoidRootPart")
				if finalHrp then
					Collect(coin, finalHrp)
				end
			end
		end)

		if handles then
			handles:Destroy()
		end
		for _, v in indicators do
			if v and v.Parent then
				v:Destroy()
			end
		end

		if not success then
			warn("navigateToCoin error:", err)
		end

		STATUS = "Waiting..."
	end

	if autofarmConnection then
		return
	end

	autofarmConnection = RunService.Heartbeat:Connect(function(dT)

		if coinInfo.Visible then
			coinInfo.Status.Text = `Status: {STATUS}`
			coinInfo.Hour.Text = `{COINS_PER_HOUR} per hour`
			coinInfo.Coins.Text = `Collected: {TOTAL_COLLECTED}`
		end

		if module.Global.coinAutofarm and not activeCoin then
			coinInfo.Visible = true

			local character = player.Character
			if not character then return end

			local hrp = character:FindFirstChild("HumanoidRootPart")
			local humanoid = character:FindFirstChild("Humanoid")
			if not hrp or not humanoid then return end

			local coin = getNearestCoin(hrp)
			if coin then
				activeCoin = coin
				task.spawn(function()
					controls:Disable()
					navigateToCoin(coin)
					controls:Enable()
					activeCoin = nil
				end)
			else
				STATUS = "Waiting..."
			end
		elseif not module.Global.coinAutofarm then
			coinInfo.Visible = false
		end
	end)
end



return module

