module.Button = function(button : TextButton, callback : () -> ())
	local scale = Instance.new("UIScale", button)
	
	button.AutoButtonColor = false
	
	button.MouseEnter:Connect(function()
		local Gradient : UIGradient = button:FindFirstChild("Gradient")
		if Gradient then
			Gradient.Offset = Vector2.new(-1,0)
			TweenService:Create(Gradient, TweenInfo.new(0.25, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {Offset = Vector2.new(1,0)}):Play()
		end
	end)
	button.MouseLeave:Connect(function()
		TweenService:Create(scale, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1}):Play()
	end)
	button.MouseButton1Down:Connect(function()
		TweenService:Create(scale, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.95}):Play()
	end)
	button.MouseButton1Up:Connect(function()
		TweenService:Create(scale, TweenInfo.new(0.1, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), {Scale = 1}):Play()
	end)
	
	button.MouseButton1Click:Connect(function()
		if button:GetAttribute("Disabled") then return end
		callback()
	end)
