module.SwitchButton = function(button, value)
	local stroke = button:FindFirstChild("UIStroke")
	
	if value then
		stroke.Color = Color3.fromRGB(100, 135, 83)
		button.BackgroundColor3 = Color3.fromRGB(162, 220, 135)
	else
		stroke.Color = Color3.fromRGB(56, 58, 68)
		button.BackgroundColor3 = Color3.fromRGB(108, 111, 131)
	end	
end

module.SwitchTab = function(id)
	local tabs = module.HUD.Game.Tabs
	local activeTab = _G.activeTab
	if activeTab == "" then
		_G.activeTab = id
		
		local tab = tabs:FindFirstChild(id)
		if tab then
			tab.Visible = true
		end
	else
		local tab = tabs:FindFirstChild(activeTab)
		if tab then
			tab.Visible = false
		end
		
		_G.activeTab = id
		local tab = tabs:FindFirstChild(id)
		if tab then
			tab.Visible = true
		end
	end
end

module.NewTab = function(id, image, layout)
	local button = script.TabButton:Clone()
	button.ImageLabel.Image = "rbxassetid://"..image
	button.Name = id
	button.Parent = module.HUD.Game.Topbar.Tabs
	button.LayoutOrder = layout or 0
	
	local frame = script.Tab:Clone()
	frame.Name = id
	frame.Parent = module.HUD.Game.Tabs
	frame.Visible = false
	
	if id == "universal" then
		frame.Visible = true
		module.SwitchButton(button, true)
	end
	
	_G.createdTabs[id] = frame
	
	module.Button(button, function()
		module.SwitchTab(id)
		
		for i, b in module.HUD.Game.Topbar.Tabs:GetChildren() do
			if b:IsA("TextButton") then
				module.SwitchButton(b, false)
			end
		end
		
		module.SwitchButton(button, true)
	end)
	
	return frame
