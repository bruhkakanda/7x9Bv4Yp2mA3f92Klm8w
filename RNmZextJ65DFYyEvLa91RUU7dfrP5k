module.AddMover = function(button)
	local textLabel = button:WaitForChild("Title")
	local icon = button:WaitForChild("Bar")

	local PADDING = 10 

	local function update()
		local textRightEdge = (textLabel.TextBounds.X / 2)
		local xOffset = textRightEdge + PADDING + (icon.AbsoluteSize.X / 2)

		icon.Position = UDim2.new(0.5, xOffset, 0.5, 0)
	end

